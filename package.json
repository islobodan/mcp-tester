{
  "name": "mcp-tester",
  "version": "1.0.0",
  "description": "Minimal MCP client implementation for CI/CD testing of MCP servers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm run build",
    "release:minor": "npm version minor && npm run build",
    "release:major": "npm version major && npm run build",
    "release:prerelease": "npm version prerelease && npm run build",
    "release:commit": "git add package.json CHANGELOG.md && git commit -m \"chore: release $(node -p \"require('./package.json').version\")\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "jest",
    "ci-cd"
  ],
  "author": "Slobodan Ivkovic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islobodan/mcp-tester.git"
  },
  "bugs": {
    "url": "https://github.com/islobodan/mcp-tester/issues"
  },
  "homepage": "https://github.com/islobodan/mcp-tester#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}

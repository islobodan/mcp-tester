{
  "name": "@slbdn/mcp-tester",
  "version": "1.1.0",
  "description": "Minimal MCP client implementation for CI/CD testing of MCP servers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/client",
    "dist/utils",
    "dist/cli",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js.map",
    "dist/assert.js",
    "dist/assert.d.ts",
    "dist/assert.d.ts.map",
    "dist/assert.js.map",
    "dist/matchers.js",
    "dist/matchers.d.ts",
    "dist/matchers.d.ts.map",
    "dist/matchers.js.map",
    "vitest.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "docs": "typedoc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "npx tsx src/__tests__/benchmarks.ts 2>/dev/null",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "prepublishOnly": "npm run build && npm run docs",
    "release:patch": "npm version patch && npm run build",
    "release:minor": "npm version minor && npm run build",
    "release:major": "npm version major && npm run build",
    "release:prerelease": "npm version prerelease && npm run build",
    "release:commit": "git add package.json CHANGELOG.md && git commit -m \"chore: release $(node -p \"require('./package.json').version\")\"",
    "prepare": "husky || true"
  },
  "bin": {
    "mcp-tester": "dist/cli/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-tester",
    "mcp-client",
    "testing",
    "test",
    "jest",
    "vitest",
    "assert",
    "matchers",
    "ci-cd",
    "cli",
    "typescript",
    "esm"
  ],
  "author": "Slobodan Ivkovic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islobodan/mcp-tester.git"
  },
  "bugs": {
    "url": "https://github.com/islobodan/mcp-tester/issues"
  },
  "homepage": "https://github.com/islobodan/mcp-tester#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
